@* This is Partial view file *@
@using Microsoft.Extensions.Configuration
@inject IConfiguration _configuration  //we can dirrectly read appsettings.json file from View using this injection, (don't need to use Controllers or other files).

 <header>
            
                <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light br-white border-bottom box-shadow mb-3">
                    <div class="container">

                        <a class="navbar-brand" href="/">
                        <img src="~/img/Cat.png" width="60" height="60" asp-append-version="true" />
                        BookShop
                        </a>
                        @* button section for the phone -placing your content of navbar automatically*@
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                        </button>
                        
                        <div class="navbar-collapse collapse d-sm-inline-flex flex-sm-row-reverse">
                            <ul class="navbar-nav">
                                <li class="nav-item">
                                    <a class="btn btn-outline-primary" href="#">Login</a>
                                    <a class="btn btn-primary" href="#">Register</a>
                                </li>
                            </ul>

                            <ul class="navbar-nav flex-grow-1">
                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="/">Home</a>
                                </li>
                                 <li class="nav-item">
                                    <a class="nav-link text-dark" href="/book/GetAllBooks">All Books</a>
                                 </li>
                                 <li class="nav-item">
                                     <a class="nav-link text-dark" href="/book/AddNewBook">Add new book</a>
                                 </li>
                                 <li class="nav-item">
                                     <a class="nav-link text-dark" href="/about-us">About us</a>
                                 </li>
                                  <li class="nav-item">
                                     <a class="nav-link text-dark" href="/contact-us">Contact us</a>
                                 </li>

                            </ul>

                        </div>
                      
                        
                        
                       
                    </div>
                    
               
                </nav>
               
                
                @* testing bollean data type from appsettings.json, if DisplayNewBookAlert = true ---> show message *@
              @if(_configuration.GetValue<bool>("DisplayNewBookAlert")){
                
                <div class="alert alert-info" role="alert">
                This is our message
               </div>
                }
               
       
    </header>