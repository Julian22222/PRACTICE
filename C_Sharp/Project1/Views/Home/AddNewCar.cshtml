@model Car

<h1>Add New Car</h1>

<form method="post" asp-asp-controller="home" asp-action="AddNewCar" >

    <div asp-validation-summary="All" class="text-danger"></div> 

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Year"></label>
        <input asp-for="Year" class="form-control" />
        <span asp-validation-for="Year" class="text-danger"></span>
    </div>
    <div class="form-group">
        <select asp-for="FuelType" class="form-select" asp-items="ViewBag.Fuel">
            <option value="">Select Fuel Type</option>
        </select>
        <span asp-validation-for="FuelType" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="offset-sm-4 col-sm-4 d-grid" style="width: 200px;">
            <input type="submit" class="btn btn-primary" value="Submit"/>
        </div>
        <button class="col-sm-4 d-grid"  style="width: 200px; hight: 20px;">
            <a  class="btn btn-outline-primary" asp-controller="home" asp-action="Index" role="button">Cancel</a>
        </button>
    </div>


</form>