@{
    ViewData["Title"] = "Gallery";
}
<h1>This is Gallery</h1>

<div class="gallery">
    <div class="big">
        <img src="/IMG/gallery/gal2.jpg" alt="start" style="width:  1100px; height: 650px;"/>
    </div>
    <div class="small">
        <a href="/IMG/gallery/gal1.jpg"><img src="/IMG/gallery/gal1.jpg" alt="pic 1" /></a>
        <a href="/IMG/gallery/gal2.jpg"><img src="/IMG/gallery/gal2.jpg" alt="pic 2" /></a>
        <a href="/IMG/gallery/gal3.jpg"><img src="/IMG/gallery/gal3.jpg" alt="pic 3" /></a>
        <a href="/IMG/gallery/gal4.jpg"><img src="/IMG/gallery/gal4.jpg" alt="pic 4" /></a>
        <a href="/IMG/gallery/gal5.jpg"><img src="/IMG/gallery/gal5.jpg" alt="pic 5" /></a>
    </div>
</div>

<script>

    $(document).ready(function() {

        $('.small a').click(function(e) {
            if($('.big img').attr('src') != $(this).attr('href')){  //if big image is not the same as clicked image
            $('.big img').hide().attr('src', $(this).attr('href')).fadeIn(1000);  //hide image and change src on big image
           }
            e.preventDefault();  //blocking default action of <a> tag
        });


        $('.small a img').click(function() {

            $('.small a img').fadeTo(500, 1).css({
                'border': 'none',
            });  //fade all images to 100% opacity

            $(this).fadeTo(500, 0.5).css({
                'border': '1px solid red',
            });  //fade image to 50% opacity
        });

    });

</script>